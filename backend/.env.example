# Copy to backend/.env for local dev. Never commit a real .env.
# All real secrets in prod come from GCP Secret Manager via Workload Identity.

# --- Runtime mode ---
# fixture: no external calls, deterministic stubs (default for local dev + CI)
# live:    calls real Gemini + Vertex + Firestore (requires gcloud auth + billing)
EGOSYN_RUNTIME_MODE=fixture

# --- Google AI ---
# Only used in live mode. Get a key from https://aistudio.google.com/apikey
# and rotate via Secret Manager before any real user data flows.
GEMINI_API_KEY=

# Model IDs (overridable per env)
EGOSYN_MODEL_REASONING=gemini-2.5-pro
EGOSYN_MODEL_CRITIC=gemini-2.5-pro
EGOSYN_MODEL_EXTRACTION=gemini-2.5-flash
EGOSYN_MODEL_GENERATION=gemini-2.5-flash

# --- GCP project (live mode only) ---
GOOGLE_CLOUD_PROJECT=egosyntonic-dev
GOOGLE_APPLICATION_CREDENTIALS=  # path to service-account JSON for local-only dev

# --- Firebase Auth (live mode only) ---
FIREBASE_PROJECT_ID=egosyntonic-dev

# --- Vertex AI Vector Search ---
VERTEX_VECTOR_INDEX_ENDPOINT=  # populated by Terraform output
VERTEX_VECTOR_INDEX_ID=
VERTEX_REGION=us-central1

# --- Observability ---
LOG_LEVEL=INFO
EGOSYN_OTEL_ENABLED=false   # set true to ship traces to Cloud Trace

# --- Auth bypass for local dev (NEVER true in prod) ---
EGOSYN_DEV_AUTH_BYPASS=true
EGOSYN_DEV_BYPASS_USER_ID=local-dev-user
